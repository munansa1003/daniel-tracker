# Daniel Tracker — 환경변수 예시
# 이 파일을 복사해 .env 로 만들고 값을 채우세요. (.env 는 git에 커밋되지 않습니다)
#
# 로컬 개발: 프로젝트 루트의 .env 에 작성
# 배포(Vercel): 프로젝트 Settings → Environment Variables 에 등록

# ─────────────────────────────────────────────
# 프론트엔드 (빌드 시 번들에 주입 — VITE_ 접두사 필수)
# ─────────────────────────────────────────────

# Firebase App Check 용 reCAPTCHA v3 사이트 키.
# 프로덕션에서 미설정 시 App Check가 비활성화되며,
# firestore.rules(request.app != null)가 배포돼 있으면 앱이 Firestore에 접근 못 함.
VITE_RECAPTCHA_SITE_KEY=

# ─────────────────────────────────────────────
# 서버리스 함수 (api/*) — 클라이언트에 노출되지 않음
# ─────────────────────────────────────────────

# Anthropic Claude API 키 (음식/운동/체성분 AI 분석에 필수)
ANTHROPIC_API_KEY=

# 관리자 마스터 비밀번호 (프로필 삭제 / 비번 우회 검증용)
ADMIN_MASTER_KEY=

# 프로덕션 도메인 화이트리스트 (API origin 검증).
# 콤마(,)로 여러 개 지정 가능. 예: https://your-app.vercel.app,https://your-domain.com
PRODUCTION_ORIGIN=

# ─────────────────────────────────────────────
# Rate Limit 저장소 (선택 — 미설정 시 rate limit이 fail-open으로 통과됨)
# Vercel의 Upstash 통합 시 자동 주입되거나, 아래 둘 중 한 쌍을 직접 설정
# ─────────────────────────────────────────────

KV_REST_API_URL=
KV_REST_API_TOKEN=
# 또는
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# 참고: VERCEL_URL, NODE_ENV 는 Vercel이 자동 주입하므로 설정 불필요.
